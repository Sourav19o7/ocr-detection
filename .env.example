# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1
S3_BUCKET_NAME=hallmark-qc-images
S3_PREFIX=hallmark-images

# Database Configuration
DATABASE_URL=sqlite:///./hallmark_qc.db
DB_ECHO=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# OCR Configuration
OCR_AUTO_APPROVE=0.85
OCR_AUTO_REJECT=0.50

# Processing Limits
MAX_BATCH_SIZE=100
IMAGE_MAX_SIZE_MB=10
