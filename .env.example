# =============================================================================
# Hallmark QC — environment configuration
# =============================================================================
# Copy to .env and edit. Anything left unset falls back to the defaults below.
# NEVER commit the resulting .env file.

# --- S3 storage -------------------------------------------------------------
# When these are missing, the app falls back to ./uploads/ using the same key
# layout — handy for local dev without AWS access.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=hallmark-qc-images
S3_PREFIX=hallmark-images

# --- Database ---------------------------------------------------------------
# SQLite by default. Switch to Postgres in production (schema runner is
# currently sqlite3-only — port it to alembic before migrating).
DATABASE_URL=sqlite:///./hallmark_qc.db

# --- OCR decision thresholds (0.0–1.0) -------------------------------------
OCR_AUTO_APPROVE=0.85
OCR_AUTO_REJECT=0.50

# --- API bind --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- Cookie signing ---------------------------------------------------------
# Used by SessionMiddleware. A random value is generated per-boot when unset,
# but that breaks cookies across restarts — set this in production.
SESSION_SECRET=
