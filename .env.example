# =============================================================================
# Hallmark OCR API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# =============================================================================
# AWS Configuration (Required for S3 storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1
S3_BUCKET_NAME=hallmark-qc-images
S3_PREFIX=hallmark-images
S3_FOLDER_PATH=uploads/
S3_OCR_FOLDER_PATH=ocr-images/

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# For EC2 deployment, set this to your public IP or domain
# Example: http://54.123.45.67:8000 or https://api.yourdomain.com
API_BASE_URL=http://localhost:8000

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite (default)
DATABASE_URL=sqlite:///./hallmark_qc.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/hallmark_qc

DB_ECHO=false

# =============================================================================
# Authentication (Optional)
# =============================================================================
# Session secret for cookie-based auth
SESSION_SECRET=your-secure-session-secret-here

# Login users (format: user1:pass1,user2:pass2)
LOGIN_USERS=admin:password123

# =============================================================================
# OCR Configuration
# =============================================================================
# Confidence thresholds (0.0 to 1.0)
OCR_AUTO_APPROVE=0.85
OCR_AUTO_REJECT=0.50

# =============================================================================
# Processing Limits
# =============================================================================
MAX_BATCH_SIZE=100
IMAGE_MAX_SIZE_MB=10

# =============================================================================
# Debug Mode
# =============================================================================
DEBUG=false
