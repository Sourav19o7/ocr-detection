{
	"info": {
		"_postman_id": "hallmark-qc-api-collection",
		"name": "Hallmark QC API",
		"description": "AI-powered Hallmark Quality Control System with BIS compliance validation.\n\n## Three-Stage Workflow\n\n### Stage 1: Batch Upload\nUpload CSV/Excel files containing tag IDs and expected HUIDs.\n\n### Stage 2: Image Processing\nUpload hallmark images with their corresponding tag IDs for OCR processing.\n\n### Stage 3: Results Retrieval\nRetrieve OCR results, expected vs actual HUID comparison, and processed images.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://65.2.187.3:8000",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Simple health check for deployment monitoring."
					},
					"response": []
				},
				{
					"name": "API Health (Detailed)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/health",
							"host": ["{{base_url}}"],
							"path": ["api", "health"]
						},
						"description": "Detailed API health check with version and storage info."
					},
					"response": []
				}
			]
		},
		{
			"name": "Stage 1 - Batch Upload",
			"item": [
				{
					"name": "Upload Batch (CSV/Excel)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "CSV or Excel file with tag_id and expected_huid columns"
								},
								{
									"key": "batch_name",
									"value": "Test Batch",
									"type": "text",
									"description": "Optional batch name"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/stage1/upload-batch",
							"host": ["{{base_url}}"],
							"path": ["stage1", "upload-batch"]
						},
						"description": "Upload CSV/Excel file with tag IDs and expected HUIDs.\n\nThe file should have at least two columns:\n- tag_id: Unique identifier for each item\n- expected_huid: The expected HUID to validate against\n\nSupported formats: CSV, XLSX, XLS"
					},
					"response": []
				},
				{
					"name": "List All Batches",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/stage1/batches",
							"host": ["{{base_url}}"],
							"path": ["stage1", "batches"]
						},
						"description": "List all uploaded batches."
					},
					"response": []
				},
				{
					"name": "Get Batch Details",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/stage1/batch/:batch_id",
							"host": ["{{base_url}}"],
							"path": ["stage1", "batch", ":batch_id"],
							"variable": [
								{
									"key": "batch_id",
									"value": "1",
									"description": "Batch ID"
								}
							]
						},
						"description": "Get details of a specific batch including all items and statistics."
					},
					"response": []
				}
			]
		},
		{
			"name": "Stage 2 - Image Processing",
			"item": [
				{
					"name": "Upload & Process Single Image",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Hallmark image (PNG, JPG, JPEG, BMP, WEBP)"
								},
								{
									"key": "tag_id",
									"value": "TAG001",
									"type": "text",
									"description": "Tag ID from batch upload"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/stage2/upload-image",
							"host": ["{{base_url}}"],
							"path": ["stage2", "upload-image"]
						},
						"description": "Upload an image for a specific tag ID and process it.\n\nThe image will be:\n1. Stored in S3 (or local storage)\n2. Processed through OCR\n3. Compared against the expected HUID from Stage 1"
					},
					"response": []
				},
				{
					"name": "Upload & Process Bulk Images",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "files",
									"type": "file",
									"src": "",
									"description": "Multiple hallmark images (filenames should be tag_id.ext)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/stage2/upload-image-bulk",
							"host": ["{{base_url}}"],
							"path": ["stage2", "upload-image-bulk"]
						},
						"description": "Upload multiple images at once.\n\nImage filenames should contain the tag_id (e.g., TAG001.jpg, TAG002.png)."
					},
					"response": []
				}
			]
		},
		{
			"name": "Stage 3 - Results",
			"item": [
				{
					"name": "Get Result by Tag ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/stage3/result/:tag_id",
							"host": ["{{base_url}}"],
							"path": ["stage3", "result", ":tag_id"],
							"variable": [
								{
									"key": "tag_id",
									"value": "TAG001",
									"description": "Tag ID to get results for"
								}
							]
						},
						"description": "Get complete result for a specific tag ID.\n\nReturns:\n- Expected HUID (from batch upload)\n- Actual HUID (from OCR)\n- Match status\n- OCR confidence and decision\n- Original and processed image URLs"
					},
					"response": []
				},
				{
					"name": "Get Batch Results",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/stage3/batch/:batch_id/results",
							"host": ["{{base_url}}"],
							"path": ["stage3", "batch", ":batch_id", "results"],
							"variable": [
								{
									"key": "batch_id",
									"value": "1",
									"description": "Batch ID"
								}
							]
						},
						"description": "Get all results for a batch.\n\nReturns complete statistics and individual results for all items in the batch."
					},
					"response": []
				},
				{
					"name": "Search Results",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/stage3/search?tag_id=TAG001&batch_id=1&decision=approved",
							"host": ["{{base_url}}"],
							"path": ["stage3", "search"],
							"query": [
								{
									"key": "tag_id",
									"value": "TAG001",
									"description": "Search by tag ID"
								},
								{
									"key": "huid",
									"value": "ABC123",
									"description": "Search by HUID",
									"disabled": true
								},
								{
									"key": "batch_id",
									"value": "1",
									"description": "Filter by batch"
								},
								{
									"key": "decision",
									"value": "approved",
									"description": "Filter by decision (approved, rejected, manual_review)"
								}
							]
						},
						"description": "Search and filter results by various criteria."
					},
					"response": []
				}
			]
		},
		{
			"name": "S3 Presigned URLs",
			"item": [
				{
					"name": "Get Upload URL (General)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"fileName\": \"document.pdf\",\n    \"contentType\": \"application/pdf\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/get-upload-url",
							"host": ["{{base_url}}"],
							"path": ["api", "get-upload-url"]
						},
						"description": "Get a presigned URL for direct S3 upload.\n\nThis endpoint generates a presigned URL that allows direct upload to S3 from the browser without routing through the server."
					},
					"response": []
				},
				{
					"name": "Get OCR Upload URL",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"fileName\": \"hallmark_image.jpg\",\n    \"contentType\": \"image/jpeg\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/get-ocr-upload-url",
							"host": ["{{base_url}}"],
							"path": ["api", "get-ocr-upload-url"]
						},
						"description": "Get a presigned URL for OCR image uploads.\n\nThis endpoint is specifically for uploading hallmark images for OCR processing. Images are stored in a dedicated OCR folder in S3."
					},
					"response": []
				}
			]
		},
		{
			"name": "Legacy OCR Endpoints",
			"item": [
				{
					"name": "Extract Text (V1)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Image file (PNG, JPG, JPEG, BMP, WEBP)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/extract",
							"host": ["{{base_url}}"],
							"path": ["extract"]
						},
						"description": "Legacy endpoint: Extract text from an uploaded image using basic OCR."
					},
					"response": []
				},
				{
					"name": "Extract Text with Hallmark Detection (V2)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "",
									"description": "Hallmark image file (PNG, JPG, JPEG, BMP, WEBP)"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/extract/v2",
							"host": ["{{base_url}}"],
							"path": ["extract", "v2"]
						},
						"description": "Legacy endpoint: Extract text with hallmark detection.\n\nReturns:\n- Full OCR text\n- Hallmark information (purity code, karat, HUID, BIS certification)\n- Individual detection results with confidence scores"
					},
					"response": []
				}
			]
		},
		{
			"name": "QC & Validation",
			"item": [
				{
					"name": "Get QC Rules",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/qc/rules",
							"host": ["{{base_url}}"],
							"path": ["qc", "rules"]
						},
						"description": "Get current QC validation rules and BIS compliance standards.\n\nIncludes:\n- Gold grades (375, 585, 750, 875, 916, 958, 999)\n- Silver grades (800, 925, 950, 999)\n- HUID format requirements\n- Confidence thresholds for auto-approve/reject"
					},
					"response": []
				},
				{
					"name": "Validate HUID Format",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "huid",
									"value": "ABC123",
									"type": "text",
									"description": "HUID to validate"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/validate/huid",
							"host": ["{{base_url}}"],
							"path": ["validate", "huid"]
						},
						"description": "Validate HUID format.\n\nHUID requirements:\n- 6 alphanumeric characters\n- Must contain at least one letter"
					},
					"response": []
				}
			]
		}
	]
}
